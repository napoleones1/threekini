{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/server.js" },
    { "src": "/uploads/(.*)", "dest": "server/server.js" },
    { "src": "/admin/(.*)", "dest": "server/server.js" },
    { "src": "/admin", "dest": "server/server.js" },
    { "src": "/article(.*)", "dest": "server/server.js" },
    { "src": "/category(.*)", "dest": "server/server.js" },
    { "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|svg|webp))", "dest": "server/server.js" },
    { "src": "/(.*)", "dest": "server/server.js" }
  ]
}
