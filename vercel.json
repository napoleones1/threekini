{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/server.js" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/article.html", "dest": "/article.html" },
    { "src": "/category.html", "dest": "/category.html" },
    { "src": "/admin/login.html", "dest": "/admin/login.html" },
    { "src": "/admin/dashboard.html", "dest": "/admin/dashboard.html" },
    { "src": "/uploads/(.*)", "dest": "server/server.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
